{
  "compilerOptions": {
    "target": "es2020",
    "module": "Node16",
    "rootDir": ".",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": [
    "src",
    "tests"
  ]
}
